{
  "name": "zig-crypto",
  "version": "0.2.9",
  "description": "A zero-allocation, N-ABI-stable Node.js native extension for high-performance nanoid and Snowflake ID generation, written in Zig",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "prebuilds",
    "LICENSE",
    "README.md"
  ],
  "preferUnplugged": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "tsc",
    "test": "tsc && node dist/test/test.js",
    "prebuild": "node-gyp-build",
    "prepare": "husky"
  },
  "dependencies": {
    "nanoid": "^5.1.11",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "node-api-headers": "^0.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.3.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Coderx85/zig-crypto-library.git"
  },
  "keywords": [
    "nanoid",
    "snowflake",
    "id",
    "zig",
    "native",
    "n-api",
    "bigint"
  ],
  "license": "MIT"
}
