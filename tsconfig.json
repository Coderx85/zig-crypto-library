{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "declaration": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@": ["./index.d.ts"]
    }
  },
  "include": [
    "index.d.ts",
    "examples/**/*.example.ts"
  ]
}
