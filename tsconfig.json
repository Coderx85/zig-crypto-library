{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@": ["./index.ts"],
      "@types/*": ["./types/*"]
    }
  },
  "include": [
    "index.ts",
    "types/**/*.ts",
    "test/**/*.ts",
    "examples/**/*.ts",
    "node-gyp-build.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
